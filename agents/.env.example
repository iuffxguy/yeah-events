# Copy to .env and fill in values before building the Docker container

# Vercel Postgres connection string (get from Vercel dashboard → Storage → Connect)
DATABASE_URL=postgresql://...

# Ollama server (defaults to 192.168.4.172:11434 if not set)
OLLAMA_URL=http://192.168.4.172:11434

# Ollama model (defaults to qwen2.5-coder:14b-instruct-q4_K_M if not set)
OLLAMA_MODEL=qwen2.5-coder:14b-instruct-q4_K_M
